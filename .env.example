# 거래 모드: mock (모의투자) | real (실제투자)
TRADING_MODE=mock

# 모의투자 설정 (https://openapivts.koreainvestment.com:29443)
MOCK_APP_KEY=your_mock_app_key
MOCK_APP_SECRET=your_mock_app_secret
MOCK_ACCOUNT_NO=12345678-01

# 실제투자 설정 (https://openapi.koreainvestment.com:9443)
REAL_APP_KEY=your_real_app_key
REAL_APP_SECRET=your_real_app_secret
REAL_ACCOUNT_NO=12345678-01

# 매매 설정
ORDER_QUANTITY=1
CHECK_INTERVAL_MINUTES=60
MAX_POSITIONS=5

# 스캔 설정
# SCAN_ALL_STOCKS=true  → KOSPI+KOSDAQ 전종목 스캔 (~2,500개, 약 2분 소요)
# SCAN_ALL_STOCKS=false → 거래량 상위 30개만 스캔
SCAN_ALL_STOCKS=false

# 이동평균 전략 설정
MA_SHORT_PERIOD=5
MA_LONG_PERIOD=20

# 카카오톡 알림 설정 (선택)
# 초기 설정: python notifications/kakao_setup.py
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
KAKAO_ACCESS_TOKEN=
KAKAO_REFRESH_TOKEN=
