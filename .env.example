# ── 대시보드 보안 설정 (필수) ──────────────────────────────────────────────
# python -c "import secrets; print(secrets.token_hex(32))" 로 생성
DASHBOARD_SECRET_KEY=your-secret-key-here
# 관리자 계정 (기본값: admin / cjswotl → 반드시 변경)
DASHBOARD_ADMIN_USER=admin
DASHBOARD_ADMIN_PASS=cjswotl

# 거래 모드: mock (모의투자) | real (실제투자)
TRADING_MODE=mock

# 모의투자 설정 (https://openapivts.koreainvestment.com:29443)
MOCK_APP_KEY=your_mock_app_key
MOCK_APP_SECRET=your_mock_app_secret
MOCK_ACCOUNT_NO=12345678-01

# 실제투자 설정 (https://openapi.koreainvestment.com:9443)
REAL_APP_KEY=your_real_app_key
REAL_APP_SECRET=your_real_app_secret
REAL_ACCOUNT_NO=12345678-01

# 매매 설정
ORDER_QUANTITY=0
CHECK_INTERVAL_MINUTES=60
MAX_POSITIONS=5
TAKE_PROFIT_RATE=5.0
# 손절 기준 (매입가 대비 하락 %, 0 = 비활성화)
STOP_LOSS_PCT=5

# 실전 예산 설정 (TRADING_MODE=real 일 때만 사용)
# 포지션당 예산 = REAL_BUDGET / MAX_POSITIONS (예: 1,000,000 / 5 = 200,000원)
# 현재가가 포지션당 예산을 초과하는 종목은 자동 스킵
# 매수 수량 = 포지션당 예산 // 현재가 (자동 계산)
REAL_BUDGET=500000
# 해외주식 예산 (USD) — 나스닥 실전 사용 시
REAL_USD_BUDGET=750.0

# 스캔 설정
# SCAN_ALL_STOCKS=true  → KOSPI+KOSDAQ 전종목 스캔 (~2,500개, 약 2분 소요)
# SCAN_ALL_STOCKS=false → 거래량 상위 30개만 스캔
SCAN_ALL_STOCKS=false

# 이동평균 전략 설정
MA_SHORT_PERIOD=5
MA_LONG_PERIOD=20

# 카카오톡 알림 설정 (선택)
# 초기 설정: python notifications/kakao_setup.py
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
KAKAO_ACCESS_TOKEN=
KAKAO_REFRESH_TOKEN=
